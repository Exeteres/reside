enum PostgresDatabaseKind {
  REPLICA
  TEMPORARY
}

/// Represents PostgreSQL credentials for a replica database.
model PostgresDatabase {
  /// The unique numeric identifier of the PostgreSQL database record.
  id Int @id @default(autoincrement())

  /// The name of the database and user to be created for the replica.
  database String @unique

  /// The generated password for the dedicated PostgreSQL user.
  password String

  /// The database lifecycle kind.
  kind PostgresDatabaseKind @default(REPLICA)

  /// The replica that owns the temporary database, if applicable.
  ownerReplicaName String?

  /// The timestamp after which the temporary database should be removed.
  expiresAt DateTime?

  /// The timestamp when the temporary database was removed.
  deletedAt DateTime?

  /// The timestamp when this record was created.
  createdAt DateTime @default(now())

  /// The timestamp when this record was last updated.
  updatedAt DateTime @updatedAt

  /// The operations associated with this PostgreSQL database.
  operations Operation[]

  @@index([kind, expiresAt])
  @@index([ownerReplicaName])
}
