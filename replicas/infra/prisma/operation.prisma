enum OperationType {
  PROVISION_POSTGRES_DATABASE
  PROVISION_TEMPORAL_NAMESPACE
  PROVISION_STORAGE_BUCKET
  ENSURE_GATEWAY
  DELETE_POSTGRES_DATABASE
  DELETE_TEMPORAL_NAMESPACE
  DELETE_GATEWAY
  DELETE_STORAGE_BUCKET
}

enum OperationStatus {
  PENDING
  COMPLETED
  FAILED
}

/// Represents a workflow-backed operation for a Temporal namespace or PostgreSQL database.
model Operation {
  /// The unique numeric identifier of the operation record.
  id Int @id @default(autoincrement())

  /// The user-facing operation title.
  title String

  /// The user-facing operation description.
  description String?

  /// The status of the operation.
  status OperationStatus

  /// The machine-readable failure reason.
  failureReason String?

  /// The human-readable failure message.
  failureMessage String?

  /// Optional callback endpoint for completion notifications.
  callbackEndpoint String?

  /// Optional custom payload for completion notifications.
  customData Json?

  /// The deterministic Reaper action identifier used as the Temporal workflow id, if applicable.
  reaperActionId String? @unique

  /// The type of operation being performed.
  type OperationType

  /// The ID of the Temporal namespace associated with this operation, if applicable.
  temporalNamespaceId Int?

  /// The ID of the PostgreSQL database associated with this operation, if applicable.
  postgresDatabaseId Int?

  /// The ID of the gateway associated with this operation, if applicable.
  gatewayId Int?

  /// The ID of the storage bucket associated with this operation, if applicable.
  storageBucketId Int?

  /// The Temporal namespace record associated with this operation, if applicable.
  temporalNamespace TemporalNamespace? @relation(fields: [temporalNamespaceId], references: [id], onDelete: Cascade)

  /// The PostgreSQL database record associated with this operation, if applicable.
  postgresDatabase PostgresDatabase? @relation(fields: [postgresDatabaseId], references: [id], onDelete: Cascade)

  /// The gateway record associated with this operation, if applicable.
  gateway Gateway? @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  /// The storage bucket record associated with this operation, if applicable.
  storageBucket StorageBucket? @relation(fields: [storageBucketId], references: [id], onDelete: Cascade)

  /// The timestamp when this operation record was created.
  createdAt DateTime @default(now())

  /// The timestamp when this operation record was last updated.
  updatedAt DateTime @updatedAt

  /// The timestamp when this operation was resolved (succeeded or failed).
  resolvedAt DateTime?

  @@index([createdAt])
  @@index([type, status])
}
