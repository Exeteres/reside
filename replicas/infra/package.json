{
  "name": "@replicas/infra",
  "version": "0.1.2",
  "reside": {
    "image": "ghcr.io/exeteres/reside/replicas/infra"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "biome": "biome check --write --unsafe --error-on-warnings",
    "biome:check": "biome check --error-on-warnings",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@connectrpc/connect-fastify": "catalog:",
    "@connectrpc/connect": "catalog:",
    "@temporalio/client": "catalog:",
    "@temporalio/common": "catalog:",
    "@temporalio/worker": "catalog:",
    "@temporalio/workflow": "catalog:",
    "prisma": "catalog:"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@types/pg": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@grpc/grpc-js": "catalog:",
    "@kubernetes/client-node": "catalog:",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@reside/api": "workspace:*",
    "@reside/common": "workspace:*",
    "@reside/registry": "workspace:*",
    "@reside/utils": "workspace:*",
    "pg": "catalog:"
  }
}
