{
  "name": "@replicas/engineer",
  "reside": {
    "image": "ghcr.io/exeteres/reside/replicas/engineer",
    "build": {
      "packages": ["git"],
      "commands": ["bash /app/replicas/engineer/scripts/install-coplilot-sdk.sh"]
    }
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "biome": "biome check --write --unsafe --error-on-warnings",
    "biome:check": "biome check --error-on-warnings",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@temporalio/client": "catalog:",
    "@temporalio/common": "catalog:",
    "@temporalio/worker": "catalog:",
    "@temporalio/workflow": "catalog:",
    "prisma": "catalog:",
    "@github/copilot-sdk": "catalog:"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "@grpc/grpc-js": "catalog:",
    "@octokit/auth-app": "catalog:",
    "@prisma/client": "catalog:",
    "@reside/api": "workspace:*",
    "@reside/common": "workspace:*",
    "@reside/topology": "workspace:*",
    "nice-grpc": "catalog:",
    "octokit": "catalog:",
    "zod": "catalog:"
  }
}
