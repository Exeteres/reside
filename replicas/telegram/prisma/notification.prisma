/// The concrete kind of response submitted by a user.
enum NotificationResponseType {
  /// The user selected one of the predefined actions.
  ACTION

  /// The user submitted free text.
  TEXT

  /// The user updated the notification task list.
  TASK_UPDATE

  /// The user submitted a dice response.
  DICE
}

/// The high-level notification lifecycle status used by renderers.
enum NotificationStatus {
  /// The notification has no special lifecycle state.
  REGULAR

  /// The notification is collecting or showing a planned task list.
  PLANNING

  /// The notification is actively in progress.
  IN_PROGRESS

  /// The notification completed successfully.
  COMPLETED

  /// The notification failed.
  FAILED
}

/// The status of a task attached to a notification.
enum NotificationTaskStatus {
  /// The task is planned but has not started yet.
  PLANNED

  /// The task is waiting to start.
  PENDING

  /// The task is currently in progress.
  IN_PROGRESS

  /// The task completed successfully.
  COMPLETED

  /// The task failed.
  FAILED

  /// The task was skipped and should not be performed.
  SKIPPED
}

/// Represents a user response to a notification.
model NotificationResponse {
  /// The operation identifier resolved by this response.
  operationId Int @id

  /// The kind of response.
  type NotificationResponseType

  /// The action name when the response kind is ACTION.
  actionName String?

  /// The canonical subject identifier of the responding user.
  subjectId String?

  /// The ECID of the text value when the response kind is TEXT.
  textResponseEcid String? @unique

  /// The encrypted text value when the response kind is TEXT.
  textResponse EncryptedContent? @relation(name: "NotificationResponseText", fields: [textResponseEcid], references: [ecid])

  /// The dice emoji when the response kind is DICE.
  diceEmoji String?

  /// The dice value when the response kind is DICE.
  diceValue Int?

  /// The timestamp when the response was created.
  createdAt DateTime @default(now())

  /// The operation associated with this response.
  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
}

/// Represents a Telegram topic used for channel-scoped notifications.
model NotificationTopic {
  /// The unique numeric identifier of the topic.
  id Int @id @default(autoincrement())

  /// The internal chat identifier where this topic was created.
  chatId Int

  /// The Telegram chat entity where this topic was created.
  chat Chat @relation("NotificationTopicTargetChat", fields: [chatId], references: [id], onDelete: Cascade)

  /// The ID of the notification channel associated with this topic.
  channelId Int

  /// The notification channel associated with this topic.
  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  /// The RHID of the Telegram topic thread identifier.
  threadRhid String

  /// The ECID of the raw Telegram topic payload returned by Telegram.
  threadEcid String @unique

  /// The encrypted raw Telegram topic payload returned by Telegram.
  thread EncryptedContent @relation(name: "NotificationTopicThread", fields: [threadEcid], references: [ecid])

  /// The subject that created this topic.
  creatorSubjectId String

  /// The stored topic title.
  title String

  /// Notifications delivered to this topic.
  notifications Notification[]

  /// Notification channel bindings that route messages to this topic.
  notificationChannelBindings NotificationChannelBinding[]

  /// The timestamp when this topic was created.
  createdAt DateTime @default(now())

  /// The timestamp when this topic was last updated.
  updatedAt DateTime @updatedAt

  @@unique([chatId, threadRhid])
  @@index([channelId])
  @@index([chatId])
}

/// Represents a caller-provided notification task group.
model NotificationTaskGroup {
  /// The notification this task group belongs to.
  notificationId Int

  /// The notification this task group belongs to.
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  /// The caller-provided stable group identifier within the notification.
  stableId String

  /// The stored group title.
  title String

  /// The zero-based group position in the rendered task list.
  position Int

  /// The tasks that belong to this group.
  tasks NotificationTask[]

  @@id([notificationId, stableId])
  @@index([notificationId])
}

/// Represents a caller-provided notification task.
model NotificationTask {
  /// The notification this task belongs to.
  notificationId Int

  /// The caller-provided stable group identifier within the notification.
  groupStableId String

  /// The task group this task belongs to.
  group NotificationTaskGroup @relation(fields: [notificationId, groupStableId], references: [notificationId, stableId], onDelete: Cascade)

  /// The caller-provided stable task identifier within the group.
  stableId String

  /// The stored task title.
  title String

  /// The current task status.
  status NotificationTaskStatus

  /// The zero-based task position in the rendered group.
  position Int

  /// Planning poll options that point to this task.
  planningPollOptions NotificationTaskPlanningPollOption[]

  @@id([notificationId, groupStableId, stableId])
  @@index([notificationId, groupStableId])
  @@index([status])
}

/// Represents an active Telegram poll used to edit a planning notification task list.
model NotificationTaskPlanningPoll {
  /// The unique numeric identifier of the planning poll.
  id Int @id @default(autoincrement())

  /// The notification this planning poll edits.
  notificationId Int

  /// The notification this planning poll edits.
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  /// The RHID of the Telegram poll identifier.
  pollRhid String @unique

  /// The ECID of the raw Telegram poll message payload.
  messageEcid String @unique

  /// The encrypted raw Telegram poll message payload.
  message EncryptedContent @relation(name: "NotificationTaskPlanningPollMessage", fields: [messageEcid], references: [ecid])

  /// The internal user identifier that launched the poll.
  launchedByUserId Int

  /// The Telegram user that launched the poll.
  launchedByUser User @relation(fields: [launchedByUserId], references: [id], onDelete: Cascade)

  /// The poll options mapped to notification tasks.
  options NotificationTaskPlanningPollOption[]

  /// The timestamp when this planning poll was created.
  createdAt DateTime @default(now())

  /// The timestamp when this planning poll was last updated.
  updatedAt DateTime @updatedAt

  @@index([notificationId])
  @@index([launchedByUserId])
}

/// Maps a Telegram poll option to a notification task.
model NotificationTaskPlanningPollOption {
  /// The planning poll this option belongs to.
  pollId Int

  /// The planning poll this option belongs to.
  poll NotificationTaskPlanningPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  /// The zero-based Telegram poll option identifier.
  optionId Int

  /// The notification identifier of the task represented by this poll option.
  taskNotificationId Int

  /// The group identifier of the task represented by this poll option.
  taskGroupStableId String

  /// The task identifier represented by this poll option.
  taskStableId String

  /// The notification task represented by this poll option.
  task NotificationTask @relation(fields: [taskNotificationId, taskGroupStableId, taskStableId], references: [notificationId, groupStableId, stableId], onDelete: Cascade)

  @@id([pollId, optionId])
  @@unique([pollId, taskNotificationId, taskGroupStableId, taskStableId])
  @@index([taskNotificationId, taskGroupStableId, taskStableId])
}

/// Represents a sent notification tracked by the replica.
model Notification {
  /// The unique numeric identifier of the notification.
  id Int @id @default(autoincrement())

  /// The optional operation associated with this notification response tracking.
  operationId Int? @unique

  /// The operation associated with this notification payload.
  operation Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  /// The internal chat identifier where this notification was sent.
  chatId Int

  /// The Telegram chat entity where this notification was sent.
  chat Chat @relation("NotificationTargetChat", fields: [chatId], references: [id])

  /// The ID of the notification channel associated with this operation.
  channelId Int

  /// The notification channel associated with this notification.
  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  /// The optional topic where this notification was sent.
  topicId Int?

  /// The topic where this notification was sent.
  topic NotificationTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  /// The RHID of the Telegram message identifier this notification is associated with.
  messageRhid String

  /// The ECID of the raw Telegram message payload returned by Telegram.
  messageEcid String @unique

  /// The encrypted raw Telegram message payload returned by Telegram.
  message EncryptedContent @relation(name: "NotificationMessage", fields: [messageEcid], references: [ecid])

  /// The replica subject that called notification sending API.
  callingSubjectId String?

  /// The effective replica subject on behalf of which notification was sent.
  sendAsSubjectId String?

  /// The stored title of this notification.
  title String

  /// The stored content of this notification.
  content String

  /// The high-level notification lifecycle status used by renderers.
  status NotificationStatus @default(REGULAR)

  /// The serialized list of action rows for rendering and pagination.
  /// [NotificationActionRowsData]
  actionRows Json

  /// The ordered task groups attached to this notification.
  taskGroups NotificationTaskGroup[]

  /// The active or historical planning polls created for this notification.
  taskPlanningPolls NotificationTaskPlanningPoll[]

  /// Whether this notification requires text response tracking.
  requiresTextResponse Boolean @default(false)

  /// Whether interaction with this notification requires permission checks.
  isProtected Boolean @default(false)

  /// Optional canonical subject identifier allowed to respond to this notification.
  protectedForSubjectId String?

  /// Whether callback selection should avoid accepted/chosen suffix rendering.
  expectImmediateFeedback Boolean @default(false)

  /// Whether topic messages should resolve this notification as text responses.
  acquireTopic Boolean @default(false)

  /// Dice emojis accepted as notification responses.
  acceptedDiceEmojis String[] @default([])

  /// The avatar provisioning request that references this notification.
  avatarProvisionRequest AvatarProvisionRequest?

  /// The timestamp when this notification was created.
  createdAt DateTime @default(now())

  /// The timestamp when this notification was last updated.
  updatedAt DateTime @updatedAt

  @@unique([chatId, messageRhid])
  @@index([channelId])
  @@index([chatId])
  @@index([topicId])
  @@index([status])
}
