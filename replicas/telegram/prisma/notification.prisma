/// The concrete kind of response submitted by a user.
enum NotificationResponseType {
  /// The user selected one of the predefined actions.
  ACTION

  /// The user submitted free text.
  TEXT
}

/// Represents a user response to a notification.
model NotificationResponse {
  /// The operation identifier resolved by this response.
  operationId Int @id

  /// The kind of response.
  type NotificationResponseType

  /// The action name when the response kind is ACTION.
  actionName String?

  /// The ECID of the text value when the response kind is TEXT.
  textResponseEcid String? @unique

  /// The encrypted text value when the response kind is TEXT.
  textResponse EncryptedContent? @relation(name: "NotificationResponseText", fields: [textResponseEcid], references: [ecid])

  /// The timestamp when the response was created.
  createdAt DateTime @default(now())

  /// The operation associated with this response.
  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
}

/// Represents a Telegram topic used for channel-scoped notifications.
model NotificationTopic {
  /// The unique numeric identifier of the topic.
  id Int @id @default(autoincrement())

  /// The internal chat identifier where this topic was created.
  chatId Int

  /// The Telegram chat entity where this topic was created.
  chat Chat @relation("NotificationTopicTargetChat", fields: [chatId], references: [id], onDelete: Cascade)

  /// The ID of the notification channel associated with this topic.
  channelId Int

  /// The notification channel associated with this topic.
  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  /// The RHID of the Telegram topic thread identifier.
  threadRhid String

  /// The ECID of the raw Telegram topic payload returned by Telegram.
  threadEcid String @unique

  /// The encrypted raw Telegram topic payload returned by Telegram.
  thread EncryptedContent @relation(name: "NotificationTopicThread", fields: [threadEcid], references: [ecid])

  /// The subject that created this topic.
  creatorSubjectId String

  /// The stored topic title.
  title String

  /// Notifications delivered to this topic.
  notifications Notification[]

  /// Notification channel bindings that route messages to this topic.
  notificationChannelBindings NotificationChannelBinding[]

  /// The timestamp when this topic was created.
  createdAt DateTime @default(now())

  /// The timestamp when this topic was last updated.
  updatedAt DateTime @updatedAt

  @@unique([chatId, threadRhid])
  @@index([channelId])
  @@index([chatId])
}

/// Represents a sent notification tracked by the replica.
model Notification {
  /// The unique numeric identifier of the notification.
  id Int @id @default(autoincrement())

  /// The optional operation associated with this notification response tracking.
  operationId Int? @unique

  /// The operation associated with this notification payload.
  operation Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  /// The internal chat identifier where this notification was sent.
  chatId Int

  /// The Telegram chat entity where this notification was sent.
  chat Chat @relation("NotificationTargetChat", fields: [chatId], references: [id])

  /// The ID of the notification channel associated with this operation.
  channelId Int

  /// The notification channel associated with this notification.
  channel NotificationChannel @relation(fields: [channelId], references: [id])

  /// The optional topic where this notification was sent.
  topicId Int?

  /// The topic where this notification was sent.
  topic NotificationTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  /// The RHID of the Telegram message identifier this notification is associated with.
  messageRhid String

  /// The ECID of the raw Telegram message payload returned by Telegram.
  messageEcid String @unique

  /// The encrypted raw Telegram message payload returned by Telegram.
  message EncryptedContent @relation(name: "NotificationMessage", fields: [messageEcid], references: [ecid])

  /// The replica subject that called notification sending API.
  callingSubjectId String?

  /// The effective replica subject on behalf of which notification was sent.
  sendAsSubjectId String?

  /// The stored title of this notification.
  title String

  /// The stored content of this notification.
  content String

  /// The serialized list of action rows for rendering and pagination.
  /// [NotificationActionRowsData]
  actionRows Json

  /// Whether this notification requires text response tracking.
  requiresTextResponse Boolean @default(false)

  /// Whether interaction with this notification requires permission checks.
  isProtected Boolean @default(false)

  /// Whether callback selection should avoid accepted/chosen suffix rendering.
  expectImmediateFeedback Boolean @default(false)

  /// Whether topic messages should resolve this notification as text responses.
  acquireTopic Boolean @default(false)

  /// The avatar provisioning request that references this notification.
  avatarProvisionRequest AvatarProvisionRequest?

  /// The timestamp when this notification was created.
  createdAt DateTime @default(now())

  /// The timestamp when this notification was last updated.
  updatedAt DateTime @updatedAt

  @@unique([chatId, messageRhid])
  @@index([channelId])
  @@index([chatId])
  @@index([topicId])
}
