/// Represents a Telegram chat known to the replica.
model Chat {
  /// The unique numeric identifier of the chat record.
  id Int @id @default(autoincrement())

  /// The RHID of the Telegram chat id.
  telegramRhid String @unique

  /// The ECID of the raw Telegram payload for the chat.
  dataEcid String @unique

  /// The RHID of the raw Telegram payload for the chat.
  dataRhid String @unique

  /// The encrypted raw Telegram payload for the chat.
  data EncryptedContent @relation(name: "ChatData", fields: [dataEcid], references: [ecid])

  /// Notifications delivered to this chat.
  notifications Notification[] @relation("NotificationTargetChat")

  /// Notification topics created in this chat.
  notificationTopics NotificationTopic[] @relation("NotificationTopicTargetChat")

  /// Notification channel bindings that route messages to this chat.
  notificationChannelBindings NotificationChannelBinding[]

  /// Natural language interactions tracked for this chat.
  naturalLanguageInteractions NaturalLanguageInteraction[] @relation("NaturalLanguageInteractionChat")

  /// The timestamp when this chat was created.
  createdAt DateTime @default(now())

  /// The timestamp when this chat was last updated.
  updatedAt DateTime @updatedAt
}
