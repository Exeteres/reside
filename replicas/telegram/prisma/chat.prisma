/// Represents a Telegram chat known to the replica.
model Chat {
  /// The unique numeric identifier of the chat record.
  id Int @id @default(autoincrement())

  /// The Telegram chat id.
  telegramId String @unique

  /// The raw Telegram payload for the chat.
  ///
  /// [ChatData]
  data Json

  /// The interaction contexts referencing this chat.
  contexts InteractionContext[]

  /// The timestamp when this chat was created.
  createdAt DateTime @default(now())

  /// The timestamp when this chat was last updated.
  updatedAt DateTime @updatedAt
}
