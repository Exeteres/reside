/// The types of interaction contexts that can exist, defining the scope and nature of user interactions.
enum InteractionContextType {
  /// The system context represents interactions that are not associated with any specific user or chat, such as background tasks or system events.
  SYSTEM

  /// The chat context represents interactions that occur within a specific Telegram chat, which may involve multiple users.
  CHAT

  /// The user context represents interactions that are specific to an individual Telegram user in private chat.
  USER_PRIVATE

  /// The user-in-chat context represents interactions that are specific to an individual Telegram user within the context of a specific chat.
  USER_IN_CHAT
}

/// The context in which user interactions occur, such as a specific user session or environment.
/// All contexts are immutable and are created at the time of the first interaction that initiates them.
model InteractionContext {
  /// The unique numeric identifier of the context.
  id Int @id @default(autoincrement())

  /// The type of the interaction context.
  type InteractionContextType

  /// The optional chat entity associated with this context.
  chatId Int?

  /// The optional user entity associated with this context.
  userId Int?

  /// The optional chat entity associated with this context.
  chat Chat? @relation(fields: [chatId], references: [id])

  /// The optional user entity associated with this context.
  user User? @relation(fields: [userId], references: [id])

  /// The last observed Telegram message id received from the user.
  ///
  /// This value is tracked only for USER_IN_CHAT contexts.
  lastUserMessageId Int?

  /// The timestamp when the context was created.
  /// Logically, this means the time of the first interaction that initiated this context.
  createdAt DateTime @default(now())

  /// The notifications associated with this interaction context.
  notifications Notification[]

  @@unique([type, chatId, userId])
  @@index([chatId])
  @@index([userId])
}
