/// Represents a Telegram user known to the replica.
model User {
  /// The unique numeric identifier of the user record.
  id Int @id @default(autoincrement())

  /// The RHID of the Telegram user id.
  telegramRhid String @unique()

  /// The RHID of the Telegram username.
  usernameRhid String? @unique()

  /// The ECID of the raw Telegram payload for the user.
  dataEcid String? @unique()

  /// The RHID of the raw Telegram payload for the user.
  dataRhid String? @unique()

  /// The encrypted raw Telegram payload for the user.
  data EncryptedContent? @relation(name: "UserData", fields: [dataEcid], references: [ecid])

  /// The avatars created by this user.
  createdAvatars Avatar[]

  /// The avatar provisioning requests created by this user.
  avatarProvisionRequests AvatarProvisionRequest[]

  /// Unauthorized avatar events created by this user.
  unauthorizedAvatars UnauthorizedAvatar[]

  /// NLS interactions started by this user.
  naturalLanguageInteractions NaturalLanguageInteraction[]

  /// Planning polls launched by this user.
  notificationTaskPlanningPolls NotificationTaskPlanningPoll[]

  /// The timestamp when this user was created.
  createdAt DateTime @default(now())

  /// The timestamp when this user was last updated.
  updatedAt DateTime @updatedAt
}
