model EncryptedContent {
  /// The ECID of the encrypted content.
  ecid String @id

  /// The encrypted content data.
  data String

  userData                 User?                 @relation(name: "UserData")
  chatData                 Chat?                 @relation(name: "ChatData")
  notificationResponseText NotificationResponse? @relation(name: "NotificationResponseText")
  notificationMessage      Notification?         @relation(name: "NotificationMessage")
  notificationTopicThread  NotificationTopic?    @relation(name: "NotificationTopicThread")
  notificationTaskPlanningPollMessage NotificationTaskPlanningPoll? @relation(name: "NotificationTaskPlanningPollMessage")
  avatarToken              Avatar?               @relation(name: "AvatarToken")
  naturalLanguageInteractionLastMessageLink NaturalLanguageInteraction? @relation(name: "NaturalLanguageInteractionLastMessageLink")
}
