enum OperationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum OperationType {
  WAIT_REPLICA_READY
  UNREGISTER_REPLICA
  DELETE_REPLICA_FROM_CLUSTER
}

/// Represents an operation for registration reconciliation in Alpha Replica.
model Operation {
  /// The unique numeric identifier of the operation record.
  id Int @id @default(autoincrement())

  /// The user-facing operation title.
  title String

  /// The user-facing operation description.
  description String?

  /// The status of the operation.
  status OperationStatus

  /// The machine-readable failure reason.
  failureReason String?

  /// The human-readable failure message.
  failureMessage String?

  /// Optional callback endpoint for completion notifications.
  callbackEndpoint String?

  /// Optional custom payload for completion notifications.
  customData Json?

  /// The type of operation being performed.
  type OperationType

  /// The deterministic Reaper action identifier used as the Temporal workflow id, if applicable.
  reaperActionId String? @unique

  /// The replica name associated with this registration operation.
  replicaName String?

  /// The replica associated with this registration operation.
  replica Replica? @relation(fields: [replicaName], references: [name], onDelete: SetNull)

  /// The timestamp when this operation record was created.
  createdAt DateTime @default(now())

  /// The timestamp when this operation record was last updated.
  updatedAt DateTime @updatedAt

  /// The timestamp when this operation was resolved (succeeded or failed).
  resolvedAt DateTime?

  @@index([createdAt])
  @@index([type, status])
  @@index([replicaName, status])
}
