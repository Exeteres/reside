model Account {
  id String @id @default(cuid())

  /// The RHID of the Telegram subject that owns the account.
  subjectRhid String @unique

  /// The ECID of the encrypted account balance.
  balanceEcid String @unique
  balance EncryptedContent @relation(name: "AccountBalance", fields: [balanceEcid], references: [ecid], onDelete: Restrict)

  outgoingTransactions Transaction[] @relation("TransactionSender")
  incomingTransactions Transaction[] @relation("TransactionRecipient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id String @id @default(cuid())

  senderAccountId String
  senderAccount Account @relation("TransactionSender", fields: [senderAccountId], references: [id], onDelete: Restrict)

  recipientAccountId String
  recipientAccount Account @relation("TransactionRecipient", fields: [recipientAccountId], references: [id], onDelete: Restrict)

  /// The ECID of the encrypted transaction amount.
  amountEcid String @unique
  amount EncryptedContent @relation(name: "TransactionAmount", fields: [amountEcid], references: [ecid], onDelete: Restrict)

  /// The ECID of the encrypted user-provided transfer comment.
  commentEcid String? @unique
  comment EncryptedContent? @relation(name: "TransactionComment", fields: [commentEcid], references: [ecid], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([senderAccountId, createdAt])
  @@index([recipientAccountId, createdAt])
}
