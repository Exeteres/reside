enum TransactionKind {
  ISSUE
  TRANSFER
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  APPROVED_ALWAYS
  REJECTED
}

/// A ledger account owned by a canonical subject such as `telegram:1` or `replica:alpha`.
model Account {
  subject_id String @id

  /// The ECID of the encrypted account balance.
  balanceEcid String @unique

  /// The encrypted account balance stored as a decimal string.
  balance EncryptedContent @relation(name: "AccountBalance", fields: [balanceEcid], references: [ecid], onDelete: Restrict)

  sentTransactions Transaction[] @relation("TransactionSender")
  receivedTransactions Transaction[] @relation("TransactionRecipient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// An immutable ledger transaction.
model Transaction {
  id BigInt @id @default(autoincrement())
  kind TransactionKind

  sender_subject_id String?
  sender Account? @relation("TransactionSender", fields: [sender_subject_id], references: [subject_id], onDelete: Restrict)

  recipient_subject_id String
  recipient Account @relation("TransactionRecipient", fields: [recipient_subject_id], references: [subject_id], onDelete: Restrict)

  /// The ECID of the encrypted transaction amount.
  amountEcid String @unique

  /// The encrypted transaction amount stored as a decimal string.
  amount EncryptedContent @relation(name: "TransactionAmount", fields: [amountEcid], references: [ecid], onDelete: Restrict)

  idempotencyKey String @unique
  /// The ECID of the optional encrypted transaction comment.
  commentEcid String? @unique

  /// The optional encrypted transaction comment.
  comment EncryptedContent? @relation(name: "TransactionComment", fields: [commentEcid], references: [ecid], onDelete: Restrict)

  createdAt DateTime @default(now())

  paymentRequest PaymentRequest?

  @@index([sender_subject_id, createdAt])
  @@index([recipient_subject_id, createdAt])
}

/// A user-confirmed request to transfer funds from a payer to a replica account.
model PaymentRequest {
  id Int @id @default(autoincrement())

  operationId Int @unique
  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  payerSubjectId String
  requesterSubjectId String

  /// The ECID of the encrypted requested amount.
  amountEcid String @unique

  /// The encrypted requested amount stored as a decimal string.
  amount EncryptedContent @relation(name: "PaymentRequestAmount", fields: [amountEcid], references: [ecid], onDelete: Restrict)

  idempotencyKey String @unique

  /// The ECID of the optional encrypted request comment.
  commentEcid String? @unique

  /// The optional encrypted request comment.
  comment EncryptedContent? @relation(name: "PaymentRequestComment", fields: [commentEcid], references: [ecid], onDelete: Restrict)

  status PaymentRequestStatus @default(PENDING)

  transactionId BigInt? @unique
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resolvedAt DateTime?

  @@index([payerSubjectId, status])
  @@index([requesterSubjectId, status])
}

/// A payer authorization allowing a replica to create future payments without prompting.
model PaymentAuthorization {
  id Int @id @default(autoincrement())

  payerSubjectId String
  requesterSubjectId String

  createdAt DateTime @default(now())

  @@unique([payerSubjectId, requesterSubjectId])
  @@index([requesterSubjectId])
}
