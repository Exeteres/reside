model EncryptedContent {
  /// The ECID of the encrypted content.
  ecid String @id

  /// The encrypted content data.
  data String

  accountBalance Account? @relation(name: "AccountBalance")
  transactionAmount Transaction? @relation(name: "TransactionAmount")
  transactionComment Transaction? @relation(name: "TransactionComment")
  paymentRequestAmount PaymentRequest? @relation(name: "PaymentRequestAmount")
  paymentRequestComment PaymentRequest? @relation(name: "PaymentRequestComment")
}
