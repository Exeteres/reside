{
  "name": "@replicas/rate",
  "reside": {
    "image": "ghcr.io/exeteres/reside/replicas/rate"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
